RewriteEngine On

# If the request is for an existing file (dashboard pages), serve it directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for an existing directory, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise route to api.php (for API endpoints like /send, /pending, etc.)
RewriteRule ^(.*)$ api.php [QSA,L]
